{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js dev",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/opt/node/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin && export NEXT_PUBLIC_DEBUG_MODE=false && /opt/homebrew/opt/node/bin/node node_modules/.bin/next dev -p 3200"],
      "port": 3200
    },
    {
      "name": "Next.js prod",
      "runtimeExecutable": "/opt/homebrew/opt/node/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "start"],
      "port": 3001,
      "autoPort": true
    }
  ]
}
